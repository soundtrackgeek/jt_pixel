{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JT Pixel",
  "version": "0.1.0",
  "identifier": "com.jtill.jtpixel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JT Pixel",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
