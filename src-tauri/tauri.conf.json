{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JT Pixel",
  "version": "0.14.0",
  "identifier": "com.jtill.jtpixel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JT Pixel",
        "width": 1440,
        "height": 920,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "JT Pixel",
    "category": "DeveloperTool",
    "shortDescription": "A focused pixel art and sprite animation studio",
    "longDescription": "JT Pixel is a focused desktop studio for creating pixel art and sprite animation.",
    "copyright": "Copyright © 2026 JT Pixel contributors",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0Q0VBRDNFNUM1NUUwQUEKUldTcTRGVmNQcTNPOURLTW5pYU1NNHR5Q0VYaDhXWUZuNkRvRlgxbXNYd2ltVDZXSlMvcVhwNjEK",
      "endpoints": [
        "https://github.com/soundtrackgeek/jt_pixel/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
